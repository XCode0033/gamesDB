<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Game Library</title>

    <style>
        .hidden {
            display: none;
        }

        .success {
            color: green;
            font-size: larger;
        }
        
        #searchForm {
            display: flex;
            flex-direction: column;
            
        }

        #search-section {
            display: flex;
        }

        #searchBtn {
            width: 100px;
            margin-right: 20px;
            border: 0px solid;
            border-radius: 10px;
            padding: 10px;
            transition: background-color 0.2s ease-in-out;

        }

        #searchBtn:hover {
            background-color: lightblue;
        }

     
        </style>
</head>
<body>
    <h1>Game Libary</h1>
    <a href="/">Return</a>
    <p id="deleteSuccess" class="hidden">Entry Successfully Deleted!!</p>
     <p id="librarySuccess" class="hidden">Successfully added to library!</p>
     <p id="searchSuccess" class="hidden">Search Successfull!</p>
     <h2>Search</h2>
     <form id="searchForm" action="/gameLibrary" method="GET">
        <div id="search-section">
            <div id="search-games">
            <h2><strong>Games</strong></h2>
            <div>
                <label for="game_id">ID</label>
                <input type="text" name="game_id" placeholder="ID" value="<%= filters?.game_id || "" %>">
            </div>

            <div>
                <label for="title">Title</label>
                <input type="text" name="title" placeholder="Title" value="<%= filters?.title || "" %>">
            </div>

            <div>
                <label for="genre">Genre</label>
                <input type="text" name="genre" placeholder="Genre" value="<%= filters?.genre || "" %>">
            </div>

            <div>
                <label for="rating">Rating</label>
                <input type="text" name="rating" placeholder="Rating" values="<%= filters?.rating || "" %>">
            </div>

        </div>

        <div id="search-users">
            <h2><strong>Users</strong></h2>
            <div>
                <label for="userId">ID</label>
                <input type="text" name="user_id" placeholder="User Id" value="<%= filters?.user_id || "" %>">
            </div>

            <div>
                <label for="gamertag">Gamertag</label>
                <input type="text" name="gamertag" placeholder="Gamertag" value="<%= filters?.gamertag || "" %>">
            </div>

            <div>
                <label for="console">Console</label>
                <input type="text" name="console_name" placeholder="Console" value="<%= filters?.console_name || "" %>">
            </div>

            <div>
                <label for="status">Status</label>
                <input type="text" name="status" placeholder="Status" value="<%= filters?.status || "" %>">
            </div>
            <div>
                <label for="hours_played">Hours</label>
                <input type="text" name="hours_played" placeholder="Hours Played" value="<%= filters?.hours || "" %>">
            </div>

        </div>
        </div>
        <div id="searchAndClear">
            <button id="searchBtn" type="submit">Search</button>
            <a id="clear" href="/gameLibrary">Clear</a>

        </div>
     </form>



    <% games.forEach(game => { %>
        <p><strong>ID: <%= game.game_id %></strong></p>
        <p><strong>Title: <%= game.title %></strong></p>
        <p>Genre: <%=game.genre %></p>
        <p>Rating: <%= game.rating %></p>
        <p>Description: <%= game.description %></p>
        <p>--- <strong>User Data</strong> ---</p>
        <ul>
            <p><strong>Gamertag: <%= game.gamertag %></strong></p>
            <p>Console: <%= game.console_name %></p>
            <p>Owned: <%= game.owned %></p>
            <p>Status: <%= game.status %></p>
            <p>Hours Played: <%= game.hours_played %></p>
        </ul>
        <!-- remember that everything is joined under "game" -->
        <form class="deleteForms" data-id="<%= game.library_id %>" action="/gameLibrary/<%= game.library_id %>" method="DELETE">
            <button id="deleteBtn" type="submit">Delete</button>
        </form>
    <% }); %>
        
    <script>
        const params = new URLSearchParams(window.location.search);
        const librarySuccess = document.getElementById("librarySuccess");
        const deleteSuccess = document.getElementById("deleteSuccess");
        if(params.get("created") === "true") {
            librarySuccess.classList.remove("hidden");
            librarySuccess.classList.add("success");
        }
        if(params.get("deleted") === "true") {
            deleteSuccess.classList.remove("hidden");
            deleteSuccess.classList.add("success");
        }
        const deleteForms = document.querySelectorAll(".deleteForms")
        deleteForms.forEach(deleteForm => {
            deleteForm.addEventListener("submit", async(e) => {
                e.preventDefault();
                const form = e.currentTarget;
                const id = deleteForm.dataset.id;

                const response = await fetch(`/gameLibrary/${id}`, {
                    method: "DELETE"
                })
                if (response.ok) {
                window.location.href = "/gameLibrary?deleted=true";
                
            }else {
                console.log('Error with entry deletion.')
            }
            })
        })

    </script>
</body>
</html>